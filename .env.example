# ==========================================
# AirSense India — Environment Configuration
# ==========================================
# Copy this file to '.env' and fill in your API keys.

# World Air Quality Index (WAQI) API Key
# Get key at: https://aqicn.org/data-platform/token/
WAQI_API_KEY=your_waqi_api_key_here

# OpenWeatherMap API Key
# Get key at: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_api_key_here

# TomTom Traffic API Key
# Get key at: https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here

# NASA FIRMS Active Fire Data MAPKEY
# Get key at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_KEY=your_nasa_firms_key_here

# OpenRouter AI API Key (for LLM reasoning & insights)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
